# ------------------------------------------------------------------
# ShopSphere backend — environment variables
# Copy this file to `.env` for local dev, and set the same keys in
# Vercel → Project → Settings → Environment Variables for production.
# ------------------------------------------------------------------

# MongoDB connection string (WITHOUT a trailing database name — the app
# appends "/shop-sphere" automatically).
# Example: mongodb+srv://user:password@cluster0.xxxxx.mongodb.net
MONGODB_URI=mongodb+srv://Kartik68:Kartik68@cluster0.thpxwig.mongodb.net/shop-sphere


# JWT secrets — use long, random strings (e.g. `openssl rand -hex 32`)
ACCESS_TOKEN_SECRET=kartik
REFRESH_TOKEN_SECRET=Malviya

# JWT token lifetimes (e.g. 1d, 15m, 10d)
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_EXPIRY=10d

# Stripe secret key (starts with sk_test_... or sk_live_...)
STRIPE_SECRET_KEY=

# Local server port (optional; defaults to 4000). Not used on Vercel.
PORT=4000
